# --- CS2 Insight local data (SQLite / player cfg backup / secrets — do not push) ---
backend/config.json
**/cs2-insight.config.json
cs2-insight.db
cs2-insight.db-wal
cs2-insight.db-shm
.cs2_config_backup/

# Everything under data/ except the versioned example template
data/**
!data/cs2-insight.config.example.json
!data/basic.ini

