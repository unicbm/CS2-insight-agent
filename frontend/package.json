{
  "name": "cs2-insight-agent",
  "private": true,
  "version": "2.0.3",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:clean": "node scripts/clean-dist-electron.mjs",
    "electron:copy-python": "node scripts/copy-python-for-bundle.mjs",
    "electron:stage-python": "node scripts/run-electron-stage-python.mjs",
    "electron:build": "npm run build && npm run electron:stage-python && node scripts/check-electron-bundle-prereqs.mjs && npm run electron:clean && npm exec electron-builder --",
    "electron:build:ver": "node scripts/electron-build-version.mjs",
    "deploy:r2": "node scripts/deploy-r2.mjs"
  },
  "build": {
    "appId": "com.cs2insightagent.app",
    "productName": "CS2 Insight Agent",
    "directories": {
      "output": "dist_electron"
    },
    "toolsets": {
      "winCodeSign": null
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "public/cs2-insight-logo.png"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "web",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__",
          "!**/*.pyc",
          "!**/.pytest_cache"
        ]
      },
      {
        "from": "../python",
        "to": "python",
        "filter": [
          "**/*",
          "!**/__pycache__",
          "!**/*.pyc"
        ]
      },
      {
        "from": "../pov",
        "to": "pov",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../data",
        "to": "data",
        "filter": [
          "**/*",
          "!**/.cs2_config_backup/**",
          "!**/.obs_config_backups/**",
          "!**/logs/**",
          "!**/cs2-insight.config.json",
          "!**/cs2-insight.db",
          "!**/cs2-insight.db-wal",
          "!**/cs2-insight.db-shm"
        ]
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://cs2-demo-agent.trswnca.cc"
    },
    "win": {
      "target": "nsis",
      "icon": "public/cs2-insight-logo.png",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/cs2-insight-logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "axios": "^1.7.0",
    "electron-log": "5.4.4",
    "electron-updater": "6.8.3",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.15.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.1047.0",
    "@aws-sdk/lib-storage": "3.1047.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "mime-types": "3.0.2",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "wait-on": "^9.0.10"
  }
}
